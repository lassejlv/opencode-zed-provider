{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "zed-cloud": {
      "npm": "file:///absolute/path/to/opencode-zed-provider/dist/index.js",
      "name": "Zed Cloud",
      "options": {
        "apiKey": "{env:ZED_LLM_TOKEN}"
      },
      "models": {
        "claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6",
          "limit": {
            "context": 1000000,
            "output": 64000
          },
          "attachment": true,
          "reasoning": true,
          "temperature": true,
          "tool_call": true,
          "variants": {
            "low": {
              "reasoningEffort": "low"
            },
            "medium": {
              "reasoningEffort": "medium"
            },
            "high": {
              "reasoningEffort": "high"
            },
            "max": {
              "reasoningEffort": "max"
            }
          }
        },
